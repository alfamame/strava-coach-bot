# Strava API設定（https://www.strava.com/settings/api で取得）
STRAVA_CLIENT_ID=ここにClient_IDを入力
STRAVA_CLIENT_SECRET=ここにClient_Secretを入力
STRAVA_REFRESH_TOKEN=ここにRefresh_Tokenを入力（01_get_token.py実行後に取得）

# Anthropic Claude API設定
ANTHROPIC_API_KEY=ここにAnthropic_APIキーを入力

# Gmail設定（コーチアドバイスの送信に使用）
GMAIL_ADDRESS=ここに送信元Gmailアドレスを入力
GMAIL_APP_PASSWORD=ここにGmailアプリパスワードを入力（Googleアカウント → セキュリティ → アプリパスワード）
RECIPIENT_EMAIL=ここに受信先メールアドレスを入力

# アスリートプロフィール（個人情報のためGitに上げない）
ATHLETE_AGE=ここに年齢を入力
ATHLETE_GENDER=男性
ATHLETE_WEIGHT_KG=ここに体重(kg)を入力
ATHLETE_BODY_FAT_PCT=ここに体脂肪率(%)を入力
ATHLETE_VO2MAX=ここにVO2Maxを入力
ATHLETE_ENDURANCE_LEVEL=ここに持久力レベルを入力（例: 高度な経験者）
ATHLETE_GOALS=ここに目標を入力（例: 1. 目標A / 2. 目標B）
ATHLETE_TRAINING_PLAN=ここに週間計画を入力（例: Zone2以下: 週4回 / Zone3以上: 週2回）
ATHLETE_NOTES=ここに体の注意点を入力（例: 腰痛あり / 猫背気味）
